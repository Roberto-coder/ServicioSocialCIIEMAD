---
import Layout from "../layouts/BaseLayout.astro";
import { publicaciones } from "../content/publicaciones.js";
import PageHero from "../components/PageHero.astro";
import PublicationCard from "../components/PublicationCard.astro";
import { BookOpen, Search, X, SlidersHorizontal } from "lucide-astro";

// Años únicos, descendentes
const anios = [...new Set(publicaciones.map((p) => Number(p.anio)))]
  .filter((a) => !Number.isNaN(a))
  .sort((a, b) => b - a);

// Tipos únicos, ordenados alfabéticamente
const tipos = [...new Set(publicaciones.map((p) => p.tipo))].sort();

// Agrupar publicaciones por año (ya ordenado descendente)
const grupos = anios.map((anio) => ({
  anio,
  items: publicaciones
    .filter((p) => Number(p.anio) === anio)
    .sort((a, b) => a.titulo.localeCompare(b.titulo, "es")),
}));

const total = publicaciones.length;
---

<Layout>
  <PageHero
    title="Publicaciones"
    subtitle={`Explora nuestra producción académica: ${total} publicaciones entre artículos, capítulos de libro y tesis.`}
    iconColor="guinda"
  >
    <BookOpen slot="icon" class="w-12 h-12 text-guinda" />
  </PageHero>

  <section class="max-w-6xl mx-auto px-4 pb-20 -mt-8 sm:-mt-12 font-sans">
    <!-- Barra de filtros sticky -->
    <div
      id="filters-bar"
      class="sticky top-[4.5rem] z-30 bg-white/95 backdrop-blur-md border border-gray-200 rounded-2xl shadow-sm p-4 sm:p-5 mb-8"
    >
      <!-- Fila 1: búsqueda + año -->
      <div class="flex flex-col sm:flex-row gap-3">
        <!-- Buscador -->
        <div class="relative flex-1">
          <Search class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" />
          <input
            id="search-input"
            type="search"
            placeholder="Buscar por título o autor..."
            autocomplete="off"
            class="w-full pl-10 pr-10 py-2.5 bg-gray-50 border border-gray-200 rounded-xl text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-guinda/30 focus:border-guinda/50 focus:bg-white transition-colors"
          />
          <button
            id="search-clear"
            type="button"
            aria-label="Limpiar búsqueda"
            class="hidden absolute right-2 top-1/2 -translate-y-1/2 w-6 h-6 rounded-full bg-gray-200 hover:bg-gray-300 text-gray-600 flex items-center justify-center"
          >
            <X class="w-3.5 h-3.5" />
          </button>
        </div>

        <!-- Año -->
        <div class="relative sm:w-48">
          <label for="filtro-anio" class="sr-only">Filtrar por año</label>
          <select
            id="filtro-anio"
            class="appearance-none w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-2.5 pr-10 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-guinda/30 focus:border-guinda/50 focus:bg-white transition-colors"
          >
            <option value="">Todos los años</option>
            {anios.map((anio) => <option value={anio}>{anio}</option>)}
          </select>
          <svg
            class="pointer-events-none w-4 h-4 absolute right-3 top-1/2 -translate-y-1/2 text-gray-400"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>

      <!-- Fila 2: tipos -->
      <div class="flex items-center gap-2 mt-3 flex-wrap">
        <span class="hidden sm:inline-flex items-center gap-1.5 text-xs uppercase tracking-wider text-gray-500 font-semibold mr-1">
          <SlidersHorizontal class="w-3.5 h-3.5" />
          Tipo
        </span>
        <button
          type="button"
          data-tipo=""
          class="tipo-chip is-active text-xs sm:text-sm px-3 py-1.5 rounded-full font-medium transition-all"
        >
          Todos
        </button>
        {tipos.map((tipo) => (
          <button
            type="button"
            data-tipo={tipo}
            class="tipo-chip text-xs sm:text-sm px-3 py-1.5 rounded-full font-medium transition-all"
          >
            {tipo}
          </button>
        ))}
      </div>

      <!-- Fila 3: contador + clear-all -->
      <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-100">
        <p class="text-sm text-gray-600">
          <span id="result-count" class="font-semibold text-guinda">{total}</span>
          <span id="result-label">publicaciones</span>
        </p>
        <button
          id="clear-all"
          type="button"
          class="hidden text-xs sm:text-sm font-medium text-gray-500 hover:text-guinda inline-flex items-center gap-1 transition-colors"
        >
          <X class="w-3.5 h-3.5" />
          Limpiar filtros
        </button>
      </div>
    </div>

    <!-- Lista agrupada por año -->
    <div id="pub-list" class="space-y-12">
      {grupos.map((grupo) => (
        <section class="year-group" data-year-group={grupo.anio}>
          <header class="flex items-baseline gap-3 mb-5 sticky top-[14rem] sm:top-56 z-10 bg-gradient-to-b from-white via-white/95 to-white/0 py-2 -mx-4 px-4">
            <h2 class="text-3xl sm:text-4xl font-serif text-guinda font-bold">{grupo.anio}</h2>
            <span class="year-count text-sm text-gray-500 font-medium" data-year-count={grupo.anio}>
              {grupo.items.length} {grupo.items.length === 1 ? "publicación" : "publicaciones"}
            </span>
            <div class="flex-1 h-px bg-gradient-to-r from-gray-200 to-transparent ml-2"></div>
          </header>
          <div class="grid sm:grid-cols-2 gap-4">
            {grupo.items.map((pub) => <PublicationCard {...pub} />)}
          </div>
        </section>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-16">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-100 mb-4">
        <Search class="w-8 h-8 text-gray-400" />
      </div>
      <h3 class="text-xl font-serif text-gray-800 mb-2">Sin resultados</h3>
      <p class="text-gray-600 mb-6 max-w-md mx-auto">
        Ninguna publicación coincide con los filtros actuales. Intenta con otros términos o limpia los filtros.
      </p>
      <button
        id="empty-clear"
        type="button"
        class="inline-flex items-center gap-2 bg-guinda text-white px-5 py-2.5 rounded-full font-medium hover:bg-guinda/90 transition-colors"
      >
        <X class="w-4 h-4" />
        Limpiar filtros
      </button>
    </div>
  </section>
</Layout>

<style>
  /* Estilo base de los chips de tipo */
  .tipo-chip {
    background: #f3f4f6;
    color: #374151;
    border: 1px solid transparent;
  }
  .tipo-chip:hover {
    background: #e5e7eb;
  }
  .tipo-chip.is-active {
    background: #6e1942; /* guinda */
    color: white;
    border-color: #6e1942;
  }
  .tipo-chip.is-active:hover {
    background: #5a1437;
  }

  /* Animación de entrada/salida de cards */
  .pub-card {
    transition: opacity 200ms ease, transform 200ms ease;
  }
  .pub-card.is-hidden {
    display: none;
  }

  /* Sticky de los headers de año por debajo del filter bar */
  @media (min-width: 640px) {
    .year-group > header {
      backdrop-filter: blur(6px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pub-card {
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const search = document.getElementById("search-input") as HTMLInputElement | null;
    const searchClear = document.getElementById("search-clear") as HTMLButtonElement | null;
    const filtroAnio = document.getElementById("filtro-anio") as HTMLSelectElement | null;
    const tipoChips = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".tipo-chip")
    );
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".pub-card"));
    const yearGroups = Array.from(
      document.querySelectorAll<HTMLElement>(".year-group")
    );
    const yearCounts = Array.from(
      document.querySelectorAll<HTMLElement>("[data-year-count]")
    );
    const resultCount = document.getElementById("result-count");
    const resultLabel = document.getElementById("result-label");
    const clearAll = document.getElementById("clear-all") as HTMLButtonElement | null;
    const emptyClear = document.getElementById("empty-clear") as HTMLButtonElement | null;
    const emptyState = document.getElementById("empty-state");
    const pubList = document.getElementById("pub-list");

    if (!search || !filtroAnio || !pubList) return;

    let selectedTipo = "";
    let selectedAnio = "";
    let query = "";

    const normalize = (s: string) =>
      s
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "");

    function syncClearVisibility() {
      const hasFilter = !!(query || selectedTipo || selectedAnio);
      clearAll?.classList.toggle("hidden", !hasFilter);
      searchClear?.classList.toggle("hidden", !query);
    }

    function apply() {
      const q = normalize(query.trim());
      let visibleTotal = 0;
      const perYear: Record<string, number> = {};

      cards.forEach((card) => {
        const tipo = card.getAttribute("data-tipo") || "";
        const anio = card.getAttribute("data-anio") || "";
        const titulo = card.getAttribute("data-titulo") || "";
        const autores = card.getAttribute("data-autores") || "";
        const haystack = normalize(titulo + " " + autores);

        const matchesTipo = !selectedTipo || tipo === selectedTipo;
        const matchesAnio = !selectedAnio || anio === selectedAnio;
        const matchesQuery =
          !q ||
          q
            .split(/\s+/)
            .filter(Boolean)
            .every((token) => haystack.includes(token));

        const visible = matchesTipo && matchesAnio && matchesQuery;
        card.classList.toggle("is-hidden", !visible);

        if (visible) {
          visibleTotal += 1;
          perYear[anio] = (perYear[anio] || 0) + 1;
        }
      });

      // Ocultar grupos de año vacíos + actualizar contadores
      yearGroups.forEach((group) => {
        const anio = group.getAttribute("data-year-group") || "";
        const count = perYear[anio] || 0;
        group.classList.toggle("hidden", count === 0);
      });

      yearCounts.forEach((el) => {
        const anio = el.getAttribute("data-year-count") || "";
        const count = perYear[anio] || 0;
        el.textContent = `${count} ${count === 1 ? "publicación" : "publicaciones"}`;
      });

      // Total + label
      if (resultCount) resultCount.textContent = String(visibleTotal);
      if (resultLabel) {
        resultLabel.textContent =
          visibleTotal === 1 ? "publicación" : "publicaciones";
      }

      // Empty state
      if (emptyState && pubList) {
        const isEmpty = visibleTotal === 0;
        emptyState.classList.toggle("hidden", !isEmpty);
        pubList.classList.toggle("hidden", isEmpty);
      }

      syncClearVisibility();
    }

    // Búsqueda con debounce
    let searchTimer: number | undefined;
    search.addEventListener("input", (e) => {
      query = (e.target as HTMLInputElement).value;
      window.clearTimeout(searchTimer);
      searchTimer = window.setTimeout(apply, 150);
    });

    searchClear?.addEventListener("click", () => {
      search.value = "";
      query = "";
      apply();
      search.focus();
    });

    // Filtro de año
    filtroAnio.addEventListener("change", (e) => {
      selectedAnio = (e.target as HTMLSelectElement).value;
      apply();
    });

    // Chips de tipo (single-select con toggle)
    tipoChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        const tipo = chip.getAttribute("data-tipo") || "";
        // Si vuelven a "Todos" o re-clickean el activo, vuelve a "Todos"
        if (selectedTipo === tipo && tipo !== "") {
          selectedTipo = "";
        } else {
          selectedTipo = tipo;
        }
        tipoChips.forEach((c) => {
          const cTipo = c.getAttribute("data-tipo") || "";
          c.classList.toggle("is-active", cTipo === selectedTipo);
        });
        apply();
      });
    });

    function reset() {
      query = "";
      selectedTipo = "";
      selectedAnio = "";
      search.value = "";
      filtroAnio.value = "";
      tipoChips.forEach((c) => {
        c.classList.toggle("is-active", (c.getAttribute("data-tipo") || "") === "");
      });
      apply();
      search.focus();
    }

    clearAll?.addEventListener("click", reset);
    emptyClear?.addEventListener("click", reset);

    // Atajo de teclado: "/" enfoca el buscador
    document.addEventListener("keydown", (e) => {
      if (
        e.key === "/" &&
        document.activeElement?.tagName !== "INPUT" &&
        document.activeElement?.tagName !== "TEXTAREA"
      ) {
        e.preventDefault();
        search.focus();
      }
    });
  });
</script>
