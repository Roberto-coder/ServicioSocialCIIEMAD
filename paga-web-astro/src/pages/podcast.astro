<script>
  document.addEventListener("DOMContentLoaded", () => {
    const tabs = document.querySelectorAll(".temporada-tab");
    const videos = document.querySelectorAll(".temporada-video");
  
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const temporadaId = tab.getAttribute("data-temporada");
  
        // Actualizar estilo de los tabs
        tabs.forEach((t) => {
          t.classList.remove("text-guinda", "border-b-2", "border-guinda");
          t.classList.add("text-gray-600", "hover:text-guinda");
        });
        tab.classList.add("text-guinda", "border-b-2", "border-guinda");
        tab.classList.remove("text-gray-600", "hover:text-guinda");
  
        // Mostrar el video correspondiente
        videos.forEach((video) => {
          if (video.id === `video-temporada-${temporadaId}`) {
            video.classList.remove("hidden");
          } else {
            video.classList.add("hidden");
          }
        });
      });
    });
  
    /**
     * Reemplaza un facade [data-yt-slot] por un <iframe> de youtube-nocookie con autoplay.
     * Se llama en el primer click del usuario sobre el botón play de la miniatura.
     */
    function activateFacade(slot, videoId) {
      const iframe = document.createElement("iframe");
      iframe.className = "absolute top-0 left-0 w-full h-full";
      iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0`;
      iframe.title = "Reproductor de YouTube";
      iframe.setAttribute("frameborder", "0");
      iframe.setAttribute(
        "allow",
        "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      );
      iframe.setAttribute("allowfullscreen", "");
      // Conserva la relación de aspecto (padding-top en el slot) y limpia la miniatura
      slot.innerHTML = "";
      slot.appendChild(iframe);
      slot.dataset.activated = "true";
    }

    /** Si el slot ya tiene iframe, sólo cambia el src. Si sigue siendo facade, actualiza la miniatura. */
    function setSlotVideo(slot, videoId) {
      slot.dataset.videoId = videoId;
      if (slot.dataset.activated === "true") {
        const iframe = slot.querySelector("iframe");
        if (iframe) iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0`;
        return;
      }
      // Sigue siendo facade: actualiza la miniatura para que coincida con el episodio elegido
      const img = slot.querySelector("img");
      if (img) {
        img.src = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
      }
    }

    // Click en el botón play del facade → carga el iframe con autoplay
    document.querySelectorAll("[data-yt-slot]").forEach((slot) => {
      const facade = slot.querySelector("[data-yt-facade]");
      facade?.addEventListener("click", () => {
        const videoId = slot.dataset.videoId;
        if (videoId) activateFacade(slot, videoId);
      });
    });

    // Click en un episodio → cambia el video del slot de su temporada
    document.querySelectorAll(".temporada-video").forEach((temporadaContainer) => {
      const slot = temporadaContainer.querySelector("[data-yt-slot]");
      const episodios = temporadaContainer.querySelectorAll(".episodio-item");

      episodios.forEach((episodio) => {
        episodio.addEventListener("click", () => {
          const videoId = episodio.getAttribute("data-video-id");
          if (slot && videoId) setSlotVideo(slot, videoId);

          // Resaltar el episodio seleccionado
          episodios.forEach((ep) => {
            ep.classList.remove("bg-guinda/10", "text-guinda");
            ep.classList.add("hover:bg-gray-200");
          });
          episodio.classList.add("bg-guinda/10", "text-guinda");
          episodio.classList.remove("hover:bg-gray-200");
        });
      });
    });
  });
</script>
