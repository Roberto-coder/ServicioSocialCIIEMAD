---
import Layout from "../layouts/BaseLayout.astro";
import FeatureCard from "../components/FeatureCard.astro";
import SmartImage from "../components/SmartImage.astro";
---

<Layout>
  <!-- Estilos de Swiper desde CDN -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
  />

  <!-- Slider Section -->
  <section class="w-full relative">
    <div class="swiper mySwiper h-[60vh] min-h-[320px] sm:h-[500px]">
      <div class="swiper-wrapper">
        <div class="swiper-slide relative">
          <SmartImage
            src="/slider/image1i.jpg"
            alt="Investigación Sostenible"
            class="w-full h-full object-scale-down"
            style="background-image: linear-gradient(to bottom, #0B4536, #60A917); object-position: center;"
            priority
          />
          <div
            class="absolute inset-0 bg-black bg-opacity-25 flex items-center justify-end pr-16"
          >
            <div class="text-right text-white max-w-lg">
              <h3 class="text-4xl font-bold mb-4 drop-shadow-lg">
                Investigación Sostenible
              </h3>
              <p class="text-xl drop-shadow-md">
                Desarrollamos soluciones innovadoras para un futuro sustentable
              </p>
            </div>
          </div>
        </div>
        <div class="swiper-slide relative">
          <SmartImage
            src="/slider/image2i.jpg"
            alt="Tecnología Verde"
            class="w-full h-full object-cover"
          />
          <div
            class="absolute inset-0 bg-black bg-opacity-25 flex items-center justify-end pr-16"
          >
            <div class="text-right text-white max-w-lg">
              <h3 class="text-4xl font-bold mb-4 drop-shadow-lg">
                Tecnología Verde
              </h3>
              <p class="text-xl drop-shadow-md">
                Innovación tecnológica al servicio del medio ambiente
              </p>
            </div>
          </div>
        </div>
        <div class="swiper-slide relative">
          <SmartImage
            src="/slider/image3i.jpeg"
            alt="Impacto Social"
            class="w-full h-full object-cover"
          />
          <div
            class="absolute inset-0 bg-black bg-opacity-25 flex items-center justify-end pr-16"
          >
            <div class="text-right text-white max-w-lg">
              <h3 class="text-4xl font-bold mb-4 drop-shadow-lg">
                Impacto Social
              </h3>
              <p class="text-xl drop-shadow-md">
                Generando cambios positivos en la sociedad
              </p>
            </div>
          </div>
        </div>
        <!-- Slide Servicio Social -->
        <div class="swiper-slide relative">
          <SmartImage
            src="/banner/ss1.png"
            alt="Libera tu servicio social con nosotros"
            class="w-full h-full object-cover"
          />
          <div
            class="absolute inset-0 bg-black bg-opacity-25 flex items-center justify-end pr-16"
          >
            <div class="text-right text-white max-w-lg">
              <h3 class="text-4xl font-bold mb-4 drop-shadow-lg">
                <a href="/contacto" class="hover:underline">
                  LIBERA TU SERVICIO SOCIAL CON NOSOTROS
                </a>
              </h3>
              <p class="text-xl drop-shadow-md">
                Pon en práctica tus conocimientos y habilidades, contáctanos.
              </p>
            </div>
          </div>
        </div>
        <!-- Slide Podcast Dra. Cristina -->
        <div class="swiper-slide relative">
          <SmartImage
            src="/banner/PodcastT4E5.jpg"
            alt="Podcast Dra. Cristina Ayala Azcárraga"
            class="w-full h-full object-contain"
            style="background-color: rgb(239, 225, 176);"
          />
          <div
            class="absolute inset-0 bg-black bg-opacity-25 flex items-center justify-end pr-16"
          >
            <div class="text-right text-white max-w-lg">
              <h3 class="text-4xl font-bold mb-4 drop-shadow-lg">
                <a href="/podcast" class="hover:underline">
                  NUEVO PODCAST CON LA DRA. CRISTINA AYALA AZCÁRRAGA
                </a>
              </h3>
              <p class="text-xl drop-shadow-md">
                Escucha nuestro más reciente episodio sobre sustentabilidad.
              </p>
            </div>
          </div>
        </div>
      </div>
      <div class="swiper-pagination"></div>

      <!-- Botón pausa/play del slider (solo móvil) -->
      <button
        type="button"
        id="slider-toggle"
        aria-label="Pausar slider"
        aria-pressed="false"
        class="lg:hidden absolute bottom-3 right-3 z-20 w-10 h-10 rounded-full bg-black/55 text-white flex items-center justify-center shadow-md backdrop-blur-sm hover:bg-black/75 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-white"
      >
        <svg id="slider-toggle-pause" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
          <rect x="6" y="5" width="4" height="14" rx="1"></rect>
          <rect x="14" y="5" width="4" height="14" rx="1"></rect>
        </svg>
        <svg id="slider-toggle-play" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 hidden">
          <path d="M8 5v14l11-7z"></path>
        </svg>
      </button>
    </div>
  </section>

  <!-- Texto de Muestra -->
  <section class="py-16 px-4 bg-gray-50 font-sans">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-bold text-guinda mb-6 font-sans">
        Bienvenidos a <span class="text-verde">SUSTENTA-</span><span
          class="text-guinda">LAPP</span
        >
      </h2>
      <p class="text-lg text-black leading-relaxed font-sans">
        Somos un centro de investigación comprometido con el desarrollo
        sostenible y la innovación tecnológica. Trabajamos en proyectos que
        impactan positivamente en el medio ambiente y la sociedad, promoviendo
        soluciones sustentables para un futuro mejor.
      </p>
    </div>
  </section>

  <!-- Cards Section -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-3 gap-8">
        <FeatureCard
          title="Nuestro Trabajo"
          color="verde"
          ctaHref="/nuestro-trabajo"
        >
          Desarrollamos proyectos de investigación enfocados en sostenibilidad,
          innovación tecnológica y soluciones ambientales que generen un impacto
          positivo en la sociedad.
        </FeatureCard>

        <FeatureCard
          title="¿Quiénes Somos?"
          color="guinda"
          ctaHref="/sobre-nosotros"
        >
          Somos un equipo multidisciplinario de investigadores y profesionales
          comprometidos con la generación de conocimiento y el desarrollo de
          tecnologías sustentables.
        </FeatureCard>

        <FeatureCard
          title="Publicaciones"
          color="gray"
          ctaHref="/publicaciones"
          ctaLabel="Ver publicaciones"
        >
          Explora nuestras investigaciones, artículos científicos y publicaciones
          que contribuyen al avance del conocimiento en el área de desarrollo
          sustentable.
        </FeatureCard>
      </div>
    </div>
  </section>

  <!-- Mascota Section -->
  <section class="py-12 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-serif text-guinda mb-4">
        Conozca a nuestra mascota
      </h2>
      <p class="text-gray-600 mb-6">
        Nuestra mascota saluda a la comunidad — Mr. Humedalcito
      </p>

      <div class="mx-auto w-56 h-56 relative">
        <!-- Layered images for crossfade effect -->
        <SmartImage
          id="mascota-img-0"
          src="/mascota/frame1.png"
          alt="Mascota fotograma 1"
          class="absolute inset-0 w-full h-full object-contain transition-opacity duration-150 opacity-100"
        />
        <SmartImage
          id="mascota-img-1"
          src="/mascota/frame2.png"
          alt="Mascota fotograma 2"
          class="absolute inset-0 w-full h-full object-contain transition-opacity duration-150 opacity-0"
        />
        <SmartImage
          id="mascota-img-2"
          src="/mascota/frame3.png"
          alt="Mascota fotograma 3"
          class="absolute inset-0 w-full h-full object-contain transition-opacity duration-150 opacity-0"
        />
      </div>
    </div>
  </section>

  <!-- CTA Diviértete y Aprende -->
  <section class="py-16 px-4 bg-verde text-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold mb-4">
        🎮 ¡Diviértete y aprende con nosotros!
      </h2>
      <p class="text-lg md:text-xl mb-6 opacity-95">
        ¿Quieres divertirte y aprender? ¡Envíanos un mensaje y disfruta de nuestro
        📱 videojuego móvil y una 🥽 app de realidad aumentada!
      </p>
      <a
        href="/contacto"
        class="inline-block bg-white text-guinda px-6 py-3 rounded-md font-semibold shadow hover:shadow-lg transition-transform duration-200 hover:-translate-y-0.5"
      >
        ¡Envíanos un mensaje!
      </a>
    </div>
  </section>

  <!-- Script de Swiper -->
  <script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
      import(
        "https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.mjs"
      ).then((module) => {
        const Swiper = module.default;

        const swiper = new Swiper(".mySwiper", {
          loop: true,
          autoplay: {
            delay: 4000,
            disableOnInteraction: false,
            pauseOnMouseEnter: true,
          },
          pagination: {
            el: ".swiper-pagination",
            clickable: true,
          },
          effect: "slide",
          speed: 1000,
          grabCursor: true,
        });

        // Toggle pausa/play del slider (visible en móvil)
        const toggle = document.getElementById("slider-toggle");
        const iconPause = document.getElementById("slider-toggle-pause");
        const iconPlay = document.getElementById("slider-toggle-play");
        if (toggle && iconPause && iconPlay) {
          let paused = false;
          toggle.addEventListener("click", () => {
            paused = !paused;
            if (paused) {
              swiper.autoplay?.stop();
              iconPause.classList.add("hidden");
              iconPlay.classList.remove("hidden");
              toggle.setAttribute("aria-label", "Reanudar slider");
              toggle.setAttribute("aria-pressed", "true");
            } else {
              swiper.autoplay?.start();
              iconPlay.classList.add("hidden");
              iconPause.classList.remove("hidden");
              toggle.setAttribute("aria-label", "Pausar slider");
              toggle.setAttribute("aria-pressed", "false");
            }
          });
        }
      });
    });
  </script>

  <!-- Mascota script -->
  <script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
      const imgs = [
        document.getElementById("mascota-img-0"),
        document.getElementById("mascota-img-1"),
        document.getElementById("mascota-img-2"),
      ];
      if (!imgs.every(Boolean)) return;

      let current = 0;
      const reduceMotion =
        window.matchMedia &&
        window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const INTERVAL = reduceMotion ? 1500 : 700;
      let timer = null;

      function showIndex(next) {
        imgs.forEach((el, i) => {
          if (!el) return;
          if (i === next) {
            el.classList.remove("opacity-0");
            el.classList.add("opacity-100");
          } else {
            el.classList.remove("opacity-100");
            el.classList.add("opacity-0");
          }
        });
        current = next;
      }

      function step() {
        showIndex((current + 1) % imgs.length);
      }

      function start() {
        if (timer) clearInterval(timer);
        timer = setInterval(step, INTERVAL);
      }

      function stop() {
        if (timer) {
          clearInterval(timer);
          timer = null;
        }
      }

      // En escritorio (con puntero fino) hover pausa la animación.
      if (window.matchMedia("(hover: hover) and (pointer: fine)").matches) {
        imgs.forEach((el) => {
          el.addEventListener("mouseenter", stop);
          el.addEventListener("mouseleave", start);
        });
      }

      showIndex(0);
      if (!reduceMotion) start();
    });
  </script>
</Layout>
