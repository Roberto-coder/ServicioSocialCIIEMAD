---
import Layout from "../layouts/BaseLayout.astro";
import { Users, Eye, Target, User } from "lucide-astro";
import { personas } from "../content/personas.js";
import PageHero from "../components/PageHero.astro";
import IconBadge from "../components/IconBadge.astro";
import SmartImage from "../components/SmartImage.astro";
---

<Layout>
  <PageHero title="Sobre Nosotros">
    <Users slot="icon" class="w-12 h-12 text-guinda" />
    <p class="text-lg text-gray-700 leading-relaxed">
      <span class="font-bold text-verde">SUSTENTA-LAPP</span> está conformado por
      un <span class="font-bold">equipo interdisciplinario</span> de profesionales
      provenientes de áreas como políticas públicas, ciencias ambientales, economía,
      derecho, urbanismo, innovación tecnológica y comunicación. Esta diversidad
      nos permite abordar los desafíos de la sustentabilidad con una visión integral
      y colaborativa.
    </p>
  </PageHero>

  <!-- Misión y Visión -->
  <section id="mision-vision" class="bg-gray-50 py-16 font-sans">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12">
        <div class="text-center">
          <div class="flex justify-center mb-4">
            <IconBadge color="verde" size="sm" pulse>
              <Target class="w-8 h-8 text-verde" />
            </IconBadge>
          </div>
          <h2 class="text-3xl font-serif text-verde mb-4">Nuestra Misión</h2>
          <p class="text-gray-700 text-lg leading-relaxed">
            SUSTENTA-LAPP tiene como misión generar, analizar y promover
            políticas públicas innovadoras y participativas que impulsen la
            transición hacia un desarrollo sustentable, integrando el
            conocimiento científico, la inclusión social y la corresponsabilidad
            ambiental desde lo local hasta lo global.
          </p>
        </div>
        <div class="text-center">
          <div class="flex justify-center mb-4">
            <IconBadge color="guinda" size="sm" pulse>
              <Eye class="w-8 h-8 text-guinda" />
            </IconBadge>
          </div>
          <h2 class="text-3xl font-serif text-guinda mb-4">Nuestra Visión</h2>
          <p class="text-gray-700 text-lg leading-relaxed">
            Ser una plataforma clave para la creación, prueba y evaluación de
            políticas públicas sustentables, sirviendo como un espacio de
            experimentación, análisis y articulación entre actores sociales,
            gubernamentales y académicos, que contribuya a la formulación de
            soluciones innovadoras, eficaces y justas frente a los desafíos
            socioambientales contemporáneos.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección de Valores -->
  <section class="bg-gray-50 py-16 font-sans">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-serif text-guinda mb-8">Nuestros Valores</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="space-y-2 text-center">
          <div class="text-4xl animate-bounce motion-reduce:animate-none">
            🌱
          </div>
          <h3 class="text-xl font-semibold text-verde">Sostenibilidad</h3>
          <p class="text-gray-600">Compromiso con el futuro del planeta</p>
        </div>
        <div class="space-y-2 text-center">
          <div class="text-4xl animate-bounce motion-reduce:animate-none">
            🤝
          </div>
          <h3 class="text-xl font-semibold text-verde">Colaboración</h3>
          <p class="text-gray-600">
            Trabajo interdisciplinario y participativo
          </p>
        </div>
        <div class="space-y-2 text-center">
          <div class="text-4xl animate-bounce motion-reduce:animate-none">
            🔬
          </div>
          <h3 class="text-xl font-semibold text-verde">Rigor Científico</h3>
          <p class="text-gray-600">Investigación basada en evidencia</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección del Equipo -->
  <section id="equipo" class="py-20 bg-white font-sans">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-16">
        <div class="flex justify-center mb-6">
          <IconBadge color="verde" pulse>
            <User class="w-12 h-12 text-verde" />
          </IconBadge>
        </div>
        <h2 class="text-4xl font-serif text-guinda mb-4">Nuestro Equipo</h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          Conoce a los profesionales que conforman SUSTENTA-LAPP, un grupo
          interdisciplinario comprometido con la investigación y el desarrollo
          sostenible.
        </p>
      </div>

      <!-- Grid del Equipo -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          personas.map((miembro) => (
            <article class="bg-white border border-gray-200 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden group transform motion-reduce:transform-none hover:-translate-y-1">
              <div class="aspect-square overflow-hidden">
                <SmartImage
                  src={miembro.foto}
                  alt={miembro.nombre}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
              <div class="p-6">
                <h3 class="text-xl font-bold text-guinda mb-1">
                  {miembro.nombre}
                </h3>
                <p class="text-verde font-medium mb-4">{miembro.titulo}</p>
                <div class="flex flex-wrap gap-2 mb-4">
                  {miembro.especialidades.slice(0, 2).map((especialidad) => (
                    <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded-full">
                      {especialidad}
                    </span>
                  ))}
                </div>
                <a
                  href={`/equipo/${miembro.id}`}
                  class="inline-flex items-center justify-center w-full bg-verde text-white px-4 py-2 rounded-lg hover:bg-green-700 transition-colors duration-200 font-medium transform hover:scale-105"
                >
                  <User class="w-4 h-4 mr-2" />
                  Ver perfil completo
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
