---
// Layout para posts del blog (p1..p5). Elimina la duplicación de marcado.
import BaseLayout from "./BaseLayout.astro";
import SmartImage from "../components/SmartImage.astro";

interface Props {
  title: string;
  date: string;
  author: string;
  image: string;
}

const { title, date, author, image } = Astro.props;
---

<BaseLayout>
  <main class="max-w-3xl mx-auto px-4 py-12">
    <article class="bg-white rounded-xl shadow-md overflow-hidden">
      <div class="h-64 bg-gray-100 overflow-hidden">
        <SmartImage
          src={image}
          alt={title}
          class="w-full h-full object-cover"
        />
      </div>
      <div class="p-8">
        <h1 class="text-2xl sm:text-3xl font-serif text-guinda mb-3">{title}</h1>
        <div class="text-sm text-gray-500 mb-6">{date} · {author}</div>

        <div class="prose max-w-none text-gray-700">
          <slot />
        </div>

        <div class="mt-8">
          <a href="/blog" class="text-guinda hover:underline">← Volver al Blog</a>
        </div>
      </div>
    </article>
  </main>
</BaseLayout>
